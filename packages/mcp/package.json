{
  "name": "@telic/mcp",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "telic-mcp": "./dist/server.js"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run --root ../.. packages/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@telic/context": "*",
    "@telic/core": "*",
    "@telic/protocol": "*",
    "zod": "4.4.3"
  }
}
